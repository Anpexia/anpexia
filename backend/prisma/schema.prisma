// ==========================================
// CONVÊNIOS
// ==========================================

model Convenio {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  nome      String
  codigo    String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pacientes      PatientConvenio[]
  tussProcedures TussProcedure[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("convenios")
}

model PatientConvenio {
  id                String    @id @default(cuid())
  patientId         String    @map("patient_id")
  convenioId        String    @map("convenio_id")
  numeroCarteirinha String    @map("numero_carteirinha")
  validade          DateTime?
  titular           String    @default("PROPRIO")
  nomeTitular       String?   @map("nome_titular")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  patient       Customer      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  convenio      Convenio      @relation(fields: [convenioId], references: [id], onDelete: Cascade)
  autorizacoes  Autorizacao[]

  @@unique([patientId, convenioId])
  @@index([patientId])
  @@index([convenioId])
  @@map("patient_convenios")
}

model Autorizacao {
  id                String    @id @default(cuid())
  patientConvenioId String    @map("patient_convenio_id")
  tenantId          String    @map("tenant_id")
  procedimento      String
  codigoTUSS        String?   @map("codigo_tuss")
  numeroAutorizacao String?   @map("numero_autorizacao")
  status            String    @default("PENDENTE")
  dataSolicitacao   DateTime  @default(now()) @map("data_solicitacao")
  dataResposta      DateTime? @map("data_resposta")
  observacoes       String?
  criadoPor         String?   @map("criado_por")

  patientConvenio PatientConvenio @relation(fields: [patientConvenioId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([patientConvenioId])
  @@index([tenantId])
  @@map("autorizacoes")
}

// ==========================================
// TENANT SETTINGS
// ==========================================

model TenantSettings {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id")
  cnpj      String?
  horarios  Json?    // { seg: { ativo: true, inicio: "08:00", fim: "18:00" }, ... }
  duracaoConsultaPadrao Int? @default(30) @map("duracao_consulta_padrao") // minutos
  emailEnabled     Boolean @default(false) @map("email_enabled")
  emailFrom        String? @map("email_from")
  emailWelcome     Boolean @default(true) @map("email_welcome")
  emailConfirmacao Boolean @default(true) @map("email_confirmacao")
  emailLembrete    Boolean @default(true) @map("email_lembrete")
  emailCancelamento Boolean @default(true) @map("email_cancelamento")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ==========================================
// TISS — FATURAMENTO DE CONVENIOS
// ==========================================

model TussProcedure {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  code        String
  description String
  type        String   // CONSULTA, EXAME, CIRURGIA, TERAPIA, OUTROS
  value       Float
  convenioId  String?  @map("convenio_id")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  convenio Convenio? @relation(fields: [convenioId], references: [id], onDelete: SetNull)

  scheduledCallProcedures ScheduledCallProcedure[]

  @@index([tenantId])
  @@index([convenioId])
  @@map("tuss_procedures")
}

model ScheduledCallProcedure {
  id                  String   @id @default(cuid())
  scheduledCallId     String   @map("scheduled_call_id")
  tussProcedureId     String   @map("tuss_procedure_id")
  authorizationNumber String?  @map("authorization_number")
  createdAt           DateTime @default(now()) @map("created_at")

  scheduledCall ScheduledCall @relation(fields: [scheduledCallId], references: [id], onDelete: Cascade)
  tussProcedure TussProcedure @relation(fields: [tussProcedureId], references: [id], onDelete: Restrict)

  @@index([scheduledCallId])
  @@index([tussProcedureId])
  @@map("scheduled_call_procedures")
}

model DoctorRepasse {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  doctorId      String   @map("doctor_id")
  procedureType String   @map("procedure_type") // CONSULTA, EXAME, CIRURGIA, TERAPIA, OUTROS
  percentage    Float    @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctor User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, doctorId, procedureType])
  @@index([tenantId])
  @@index([doctorId])
  @@map("doctor_repasses")
}

model ProcedureTemplate {
  id          String              @id @default(cuid())
  tenantId    String              @map("tenant_id")
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime            @default(now()) @map("created_at")
  materials   ProcedureMaterial[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("procedure_templates")
}

model ProcedureMaterial {
  id         String            @id @default(cuid())
  templateId String            @map("template_id")
  template   ProcedureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId  String            @map("product_id")
  product    Product           @relation(fields: [productId], references: [id])
  quantity   Float             @default(1)

  @@unique([templateId, productId])
  @@index([templateId])
  @@index([productId])
  @@map("procedure_materials")
}
