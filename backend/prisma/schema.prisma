  patient Customer @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([patientId])
  @@map("prescriptions")
}

enum PrescriptionType {
  MEDICAMENTO
  EXAME_EXTERNO
  OCULOS
  EXAME_INTERNO
}

