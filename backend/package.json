{
  "name": "anpexia-backend",
  "version": "0.1.0",
  "description": "Anpexia — API de automação empresarial",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/app.js",
    "db:deploy": "node prisma/load-env.js migrate deploy",
    "db:generate": "node prisma/load-env.js generate",
    "db:migrate": "node prisma/load-env.js migrate dev",
    "db:push": "node prisma/load-env.js db push",
    "db:studio": "node prisma/load-env.js studio",
    "test:schema": "node --import tsx --test tests/schema.test.ts",
    "test:clinical-notes": "node --import tsx --test tests/clinicalNotes.service.test.ts",
    "test:anamnesis": "node --import tsx --test tests/anamnesis.service.test.ts",
    "test:all": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^6.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "prisma": "^6.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.10.0",
    "speakeasy": "^2.0.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.19.0"
  }
}
