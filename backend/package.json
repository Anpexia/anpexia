{
  "name": "anpexia-backend",
  "version": "0.1.0",
  "description": "Anpexia — API de automação empresarial",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/app.js",
    "db:deploy": "node prisma/load-env.js migrate deploy",
    "db:generate": "node prisma/load-env.js generate",
    "db:migrate": "node prisma/load-env.js migrate dev",
    "db:push": "node prisma/load-env.js db push",
    "db:studio": "node prisma/load-env.js studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "prisma": "^6.0.0",
    "resend": "^6.10.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.19.0"
  }
}
