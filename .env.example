# ============================================
# FLUXIA — Variáveis de Ambiente (REFERÊNCIA)
# ============================================
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NUNCA deve ir para o GitHub.
# ============================================

# ---------- BANCO DE DADOS ----------
# URL de conexão com o PostgreSQL.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
# Como conseguir:
#   - Local: instale o PostgreSQL e crie um banco chamado "fluxia"
#   - Railway: crie um serviço PostgreSQL e copie a DATABASE_URL do dashboard
#   - Neon/Supabase: crie um projeto e copie a connection string
DATABASE_URL="postgresql://usuario:senha@localhost:5432/fluxia?schema=public"

# ---------- JWT (Autenticação) ----------
# Chaves secretas para gerar tokens de autenticação.
# Como gerar:
#   - No terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   - Gere uma chave diferente para cada variável
JWT_SECRET=""
JWT_REFRESH_SECRET=""
# Tempo de expiração dos tokens (não precisa mudar)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---------- SERVIDOR ----------
# Porta da API (padrão: 3000)
PORT=3000
# Ambiente: "development" ou "production"
NODE_ENV="development"
# URL dos frontends (para CORS). Múltiplas origens separadas por vírgula.
# Em desenvolvimento: http://localhost:5173,http://localhost:5174,http://localhost:5175
# Em produção: URLs do Vercel + domínios personalizados
CORS_ORIGIN="http://localhost:5173"

# ---------- CRIPTOGRAFIA ----------
# Chave para criptografar campos sensíveis no banco (CPF, dados de saúde, etc.)
# DEVE ter exatamente 32 caracteres.
# Como gerar:
#   - No terminal: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=""

# ---------- EVOLUTION API (WhatsApp) ----------
# URL e chave da Evolution API para envio de mensagens via WhatsApp.
# Como conseguir:
#   1. Instale a Evolution API (self-hosted) ou use um serviço hospedado
#   2. Documentação: https://doc.evolution-api.com
#   3. Ao instalar, defina uma APIKEY — essa é a EVOLUTION_API_KEY
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY=""

# ---------- PAGAMENTOS (Mercado Pago) ----------
# Credenciais para cobranças recorrentes via Mercado Pago.
# Como conseguir:
#   1. Acesse https://www.mercadopago.com.br/developers
#   2. Crie uma aplicação
#   3. Vá em "Credenciais" > "Credenciais de produção"
#   4. Copie o Access Token e a Public Key
# Nota: para testes, use as credenciais de teste (sandbox).
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""

# ---------- IA (Chatbot) ----------
# Provedor de IA para o chatbot. Opções: "openai" ou "anthropic"
AI_PROVIDER="openai"
# Chave de API do provedor de IA.
# Como conseguir (OpenAI):
#   1. Acesse https://platform.openai.com/api-keys
#   2. Crie uma nova API key
#   3. Adicione créditos (o modelo gpt-4o-mini custa ~$0.15 por 1M tokens de input)
# Como conseguir (Anthropic):
#   1. Acesse https://console.anthropic.com/settings/keys
#   2. Crie uma nova API key
AI_API_KEY=""
# URL da API. Não precisa mudar para OpenAI. Para Anthropic: https://api.anthropic.com/v1/messages
AI_API_URL="https://api.openai.com/v1/chat/completions"
# Modelo a usar. Recomendado: gpt-4o-mini (barato e bom) ou claude-haiku-4-5-20251001
AI_MODEL="gpt-4o-mini"

# ---------- LANDING PAGE / FRONTEND ----------
# Variáveis com prefixo VITE_ ficam disponíveis no frontend (são públicas).
# Número de WhatsApp para o botão de contato na landing page.
# Formato: código do país + DDD + número, sem espaços (ex: 5511999999999)
VITE_WHATSAPP_NUMBER=""
# E-mail de contato exibido na landing page.
VITE_CONTACT_EMAIL=""

# ---------- URLs DE PRODUÇÃO ----------
# URL da API para os frontends em produção (sem /api/v1 — já está no baseURL).
# Em desenvolvimento, o Vite proxy cuida disso automaticamente.
# Em produção, defina a URL completa da API no Railway/Render.
# Exemplo: https://fluxia-api.up.railway.app/api/v1
VITE_API_URL=""
# URL do painel do cliente (para link na landing page).
# Exemplo: https://app.fluxia.com.br
VITE_APP_URL=""
